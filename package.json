  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "commander": "^14.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "typescript": "^5.9.3"
  }
}
